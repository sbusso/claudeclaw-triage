{
  "name": "claudeclaw-triage",
  "version": "0.1.0",
  "type": "extension",
  "entry": "dist/index.js",
  "provides": {
    "dbSchema": true,
    "envKeys": ["TICKET_DEV_CHANNEL_JID", "TICKET_SOURCE_REPO"],
    "containerEnvKeys": ["GH_TOKEN"],
    "allowedDomains": ["api.github.com", "*.github.com"]
  },
  "skills": ["triage", "swe"],
  "agentSkills": ["ticket-triage", "swe-agent"],
  "agents": ["triage", "swe"],
  "hooks": {
    "postInstall": "hooks/install.sh",
    "postUninstall": "hooks/uninstall.sh"
  }
}
